#!/bin/sh
set -eu

target_ip="$(getent ahostsv6 "$SUPABASE_DIRECT_HOST" | awk '/STREAM/ { print $1; exit }')"

if [ -z "$target_ip" ]; then
  echo "No IPv6 address resolved for $SUPABASE_DIRECT_HOST" >&2
  exit 1
fi

exec /usr/bin/socat \
  "TCP-LISTEN:${SUPABASE_PROXY_LISTEN_PORT},bind=${SUPABASE_PROXY_LISTEN_ADDR},reuseaddr,fork" \
  "TCP6:[${target_ip}]:${SUPABASE_DIRECT_PORT}"
