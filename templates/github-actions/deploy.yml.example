name: Deploy

on:
  workflow_dispatch:
  push:
    branches:
      - main

permissions:
  contents: read
  id-token: write

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Join tailnet
        uses: tailscale/github-action@v4
        with:
          oauth-client-id: ${{ secrets.TS_OAUTH_CLIENT_ID }}
          oauth-secret: ${{ secrets.TS_OAUTH_SECRET }}
          tags: ${{ vars.TS_TAGS || 'tag:ci' }}
          ping: ${{ secrets.DEPLOY_HOST }}

      - name: Install SSH key
        shell: bash
        run: |
          set -euo pipefail
          install -m 700 -d ~/.ssh
          printf '%s\n' "${{ secrets.DEPLOY_SSH_KEY }}" > ~/.ssh/id_ed25519
          chmod 600 ~/.ssh/id_ed25519
          ssh-keyscan -H "${{ secrets.DEPLOY_HOST }}" >> ~/.ssh/known_hosts

      - name: Deploy over Tailscale SSH path
        shell: bash
        run: |
          set -euo pipefail
          ssh -i ~/.ssh/id_ed25519 "${{ vars.DEPLOY_USER || 'gha-ssh' }}@${{ secrets.DEPLOY_HOST }}" 'sudo -u docker /bin/bash -se --' <<'REMOTE'
            set -euo pipefail
            export XDG_RUNTIME_DIR="/run/user/$(id -u)"
            export DOCKER_HOST="unix://${XDG_RUNTIME_DIR}/docker.sock"
            cd /home/docker/deploy
            set -a
            source ./registry.env
            set +a
            printf '%s\n' "$GHCR_TOKEN" | docker login ghcr.io -u "$GHCR_USERNAME" --password-stdin
            docker compose --env-file ./images.env pull
            docker compose --env-file ./images.env up -d
          REMOTE
